# ── Sentinel Configuration ────────────────────────
# Copy to .env and fill in values

# NATS
SENTINEL_NATS_URL=nats://localhost:4222

# TimescaleDB
SENTINEL_DB_HOST=localhost
SENTINEL_DB_PORT=5432
SENTINEL_DB_USER=sentinel
SENTINEL_DB_PASSWORD=sentinel_dev
SENTINEL_DB_NAME=sentinel

# Redis
SENTINEL_REDIS_URL=redis://localhost:6379/0

# Logging
SENTINEL_LOG_LEVEL=DEBUG
SENTINEL_LOG_FORMAT=console

# API Keys (optional)
SENTINEL_OPENSKY_USERNAME=
SENTINEL_OPENSKY_PASSWORD=
SENTINEL_AISSTREAM_API_KEY=
